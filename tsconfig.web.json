{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/env.d.ts",
    "src/renderer/**/*",
    "src/renderer/**/*.vue",
    "src/preload/*.d.ts",
    "src/share/**/*.ts"
  ],
  "compilerOptions": {
    "moduleResolution": "bundler",
    "composite": true,
    "paths": {
      "@renderer/*": [
        "./src/renderer/*"
      ],
      "@share/*": [
        "./src/share/*"
      ]
    }
  }
}
