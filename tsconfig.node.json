{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.*",
    "src/main/**/*",
    "src/preload/**/*",
    "src/share/**/*.ts"
  ],
  "compilerOptions": {
    "moduleResolution": "bundler",
    "module": "ESNext",
    "composite": true,
    "types": [
      "electron-vite/node"
    ],
    "paths": {
      "@share/*": [
        "./src/share/*"
      ]
    }
  }
}